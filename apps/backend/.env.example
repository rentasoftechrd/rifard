# Supabase: Project Settings > Database > Connection string (URI).
# Si usas Connection pooling (puerto 6543), añade ?pgbouncer=true al final para evitar error "prepared statement already exists".
# Formato: ...6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[TU_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_SECRET="change-me-refresh-in-production-min-32"
REFRESH_EXPIRES_IN="7d"
# Zona horaria del banco: República Dominicana (UTC-4, sin cambio de horario). No modificar para evitar desfases.
BANCO_TIMEZONE="America/Santo_Domingo"
POS_HEARTBEAT_ONLINE_SECONDS=60
# Orígenes permitidos para CORS (Flutter Web usa localhost con puerto variable)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080"
# Escuchar en todas las interfaces para que el POS (celular) pueda conectar por IP. Por defecto 0.0.0.0.
# HOST="0.0.0.0"
# Puerto del backend (por defecto 3000)
# PORT=3000
